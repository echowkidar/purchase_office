# Database (PostgreSQL - Docker)
DATABASE_URL="postgresql://cpo_admin:CHANGE_THIS_PASSWORD@db:5432/amu_cpo_db"

# NextAuth
NEXTAUTH_URL="http://your-domain-or-ip"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_SECRET="same-as-nextauth-secret"

# Gmail SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="CPO AMU <your-email@gmail.com>"

# App
NEXT_PUBLIC_APP_NAME="AMU CPO Procurement Portal"

# Docker DB Password (used by docker-compose)
DB_PASSWORD="CHANGE_THIS_PASSWORD"
